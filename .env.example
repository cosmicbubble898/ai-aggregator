# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored — NEVER commit real secrets.
# Blocks are grouped by the feature that introduces them; add them as you build.

# --- Auth: Google sign-in (added with the auth feature) ---
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_TRUST_HOST=true

# --- Database: Neon Postgres (added with auth / persistence) ---
DATABASE_URL=

# --- Encryption for per-user API keys (added with BYOK) ---
# A 32-byte key, base64-encoded.
ENCRYPTION_KEY=

# --- Media storage: Cloudflare R2 (added with the first media feature) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
