# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored — NEVER commit real secrets.
# Blocks are grouped by the feature that introduces them; add them as you build.

# --- Site URL (added with SEO/GEO; see lib/site.ts + ADR-0012) ---
# The public base URL — used for canonical links, the sitemap, Open Graph, and
# JSON-LD. Not a secret. Leave blank locally and in the current Vercel project
# (it defaults to the Vercel URL); once the custom domain is live, set this to it
# in Vercel — a one-line switch that updates every generated URL across the site.
NEXT_PUBLIC_SITE_URL=

# --- Auth: Google sign-in (added with the auth feature) ---
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_TRUST_HOST=true

# --- Database: Neon Postgres (added with auth / persistence) ---
DATABASE_URL=

# --- Encryption for per-user API keys (added with BYOK) ---
# A 32-byte key, base64-encoded.
ENCRYPTION_KEY=

# --- Media storage: Cloudflare R2 (added with the first media feature) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
